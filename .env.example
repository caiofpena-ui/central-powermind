# ── PowerMind Dashboard — Variáveis de Ambiente ──
# Copiar para .env e preencher com os valores reais

# URL pública do servidor (sem barra no final)
# Em produção: https://dashboard.powermindbr.com.br
# Em desenvolvimento: https://despise-starch-preppy.ngrok-free.dev
BASE_URL=https://dashboard.powermindbr.com.br

# Meta Ads
META_TOKEN=seu_token_meta_aqui
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret

# Yampi
YAMPI_ALIAS=powermind
YAMPI_TOKEN=seu_token_yampi
YAMPI_SECRET=seu_secret_yampi
YAMPI_EMAIL=seu_email_yampi
YAMPI_PASSWORD=sua_senha_yampi

# IA
ANTHROPIC_API_KEY=sua_chave_anthropic
OPENAI_API_KEY=sua_chave_openai

# Dashboard
ADMIN_KEY=chave_secreta_admin
DASHBOARD_USER=admin
DASHBOARD_PASS_HASH=hash_bcrypt_da_senha

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=sua_vapid_public_key
VAPID_PRIVATE_KEY=sua_vapid_private_key

# Melhor Envio
MELHOR_ENVIO_TOKEN=seu_token_melhor_envio

# Produção (define comportamento de segurança)
PRODUCTION=true
